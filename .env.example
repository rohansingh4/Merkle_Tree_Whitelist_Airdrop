# ── Required for deployment to Base mainnet ───────────────────────────────────
PRIVATE_KEY=your_private_key_no_0x_prefix
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# If true, deploys contracts/AirdropToken.sol first and uses that token.
# If false, uses AIRDROP_TOKEN_ADDRESS below.
DEPLOY_AIRDROP_TOKEN=false

AIRDROP_TOKEN_ADDRESS=0xYourExistingTokenAddressOnBase

# Use exactly one of these:
CLAIM_DEADLINE_UNIX=1767225600
# CLAIM_DEADLINE_ISO=2026-12-31T00:00:00Z

# ── Optional ───────────────────────────────────────────────────────────────────
BASESCAN_API_KEY=your_basescan_api_key
REPORT_GAS=false
